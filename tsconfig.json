{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "vite-plugin-schema-api": ["./vite-plugin-schema-api.mjs"]
    }
  },
  "include": ["src/**/*", ".storybook/preview.tsx", ".storybook/manager.tsx", "harness-vite.d.ts"]
}
