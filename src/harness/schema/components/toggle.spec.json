{
  "id": "toggle",
  "componentName": "Toggle",
  "version": "1.0.0",
  "intent": "切换按钮（按下/弹起状态），用于启用/禁用某功能或视图模式切换。",
  "wraps": {
    "module": "@/components/starter/toggle",
    "primitives": [
      "Toggle"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "variant 变体",
      "type": "\"default\" | \"outline\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "bg-transparent"
        ],
        "outline": [
          "border",
          "border-input",
          "bg-transparent",
          "hover:bg-accent",
          "hover:text-accent-foreground"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 Toggle 时从 @/components/starter/toggle 导入；切换按钮（按下/弹起状态），用于启用/禁用某功能或视图模式切换。",
  "meta": {
    "tags": [
      "toggle",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
