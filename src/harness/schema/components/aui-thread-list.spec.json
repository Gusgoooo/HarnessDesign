{
  "id": "aui-thread-list",
  "componentName": "ThreadList",
  "version": "1.0.0",
  "intent": "AI 对话历史列表，展示用户的多个对话线程。支持新建、归档、删除线程操作。",
  "wraps": {
    "module": "@/components/starter/ai/thread-list",
    "primitives": ["ThreadList"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-col",
      "gap-1",
      "rounded-lg",
      "hover:bg-muted",
      "text-sm"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖列表项圆角与间距",
        "pattern": "^(rounded|gap-)"
      },
      {
        "description": "禁止覆盖交互状态色",
        "pattern": "^(bg|text)-(muted|accent|destructive|popover)"
      },
      {
        "description": "禁止覆盖定位与层级（下拉菜单）",
        "pattern": "^(z-|fixed|absolute)"
      }
    ]
  },
  "aiPrompt": "多对话管理场景使用 ThreadList 组件；需要配合 Thread 一起使用，放在侧边栏中；ThreadList 自带新建/归档/删除功能，无需手动实现。",
  "referencePriority": [
    "@/components/starter/ai/thread-list"
  ],
  "examples": [
    {
      "title": "侧边栏 + 对话列表",
      "snippet": "<div className=\"flex h-full\">\n  <aside className=\"w-64 border-r p-2\">\n    <ThreadList />\n  </aside>\n  <main className=\"flex-1\">\n    <Thread />\n  </main>\n</div>"
    }
  ],
  "meta": {
    "tags": ["thread-list", "history", "sidebar", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
