{
  "id": "input-group",
  "componentName": "InputGroup",
  "version": "1.0.0",
  "intent": "输入框组合容器，将前缀/后缀（图标、文字、按钮）与 input 视觉合为一体。",
  "wraps": {
    "module": "@/components/starter/input-group",
    "primitives": [
      "InputGroup",
      "InputGroupAddon",
      "InputGroupButton",
      "InputGroupText",
      "InputGroupInput",
      "InputGroupTextarea"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "size",
      "description": "size 变体",
      "type": "\"xs\" | \"sm\"",
      "required": false,
      "defaultValue": "xs",
      "enumMap": {
        "xs": [
          "h-6",
          "gap-1",
          "rounded-[calc(var(--radius)-5px)]",
          "px-2",
          "has-[>svg]:px-2",
          "[&>svg:not([class*="
        ],
        "sm": [
          "h-8",
          "gap-2",
          "rounded-md",
          "px-3",
          "has-[>svg]:px-3"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "border-input",
      "shadow-xs",
      "relative",
      "flex",
      "w-full",
      "min-h-9",
      "items-stretch",
      "overflow-hidden",
      "rounded-md",
      "border",
      "outline-none"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 InputGroup 时从 @/components/starter/input-group 导入；输入框组合容器，将前缀/后缀（图标、文字、按钮）与 input 视觉合为一体。",
  "meta": {
    "tags": [
      "input-group",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
