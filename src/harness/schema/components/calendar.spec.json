{
  "id": "calendar",
  "componentName": "Calendar",
  "version": "1.0.0",
  "intent": "日期选择日历面板，用于日期范围选择器的核心渲染层。",
  "wraps": {
    "module": "@/components/starter/calendar",
    "primitives": [
      "Calendar",
      "CalendarDayButton"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "bg-background",
      "shrink-0",
      "p-3"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 Calendar 时从 @/components/starter/calendar 导入；日期选择日历面板，用于日期范围选择器的核心渲染层。",
  "meta": {
    "tags": [
      "calendar",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
