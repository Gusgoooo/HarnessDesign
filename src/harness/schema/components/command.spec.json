{
  "id": "command",
  "componentName": "Command",
  "version": "1.0.0",
  "intent": "命令面板（类 VS Code Ctrl+K / Spotlight），用于全局搜索、快捷操作入口。",
  "wraps": {
    "module": "@/components/starter/command",
    "primitives": [
      "Command",
      "CommandDialog",
      "CommandInput",
      "CommandList",
      "CommandEmpty",
      "CommandGroup",
      "CommandItem",
      "CommandShortcut",
      "CommandSeparator"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "w-full",
      "flex-col",
      "overflow-hidden",
      "rounded-md",
      "bg-popover",
      "text-popover-foreground"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 Command 时从 @/components/starter/command 导入；命令面板（类 VS Code Ctrl+K / Spotlight），用于全局搜索、快捷操作入口。",
  "meta": {
    "tags": [
      "command",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
