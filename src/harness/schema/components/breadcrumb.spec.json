{
  "id": "breadcrumb",
  "componentName": "Breadcrumb",
  "version": "1.0.0",
  "intent": "层级导航面包屑，展示当前页面在站点结构中的位置，支持逐级返回。",
  "wraps": {
    "module": "@/components/starter/breadcrumb",
    "primitives": [
      "Breadcrumb",
      "BreadcrumbList",
      "BreadcrumbItem",
      "BreadcrumbLink",
      "BreadcrumbPage",
      "BreadcrumbSeparator",
      "BreadcrumbEllipsis"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-wrap",
      "items-center",
      "gap-2",
      "break-words",
      "text-sm",
      "text-muted-foreground"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖布局结构",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      }
    ]
  },
  "aiPrompt": "使用 Breadcrumb 时从 @/components/starter/breadcrumb 导入；层级导航面包屑，展示当前页面在站点结构中的位置，支持逐级返回。",
  "meta": {
    "tags": [
      "breadcrumb",
      "navigation"
    ],
    "category": "navigation",
    "status": "stable"
  }
}
