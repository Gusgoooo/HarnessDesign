{
  "id": "business-badge",
  "componentName": "BusinessBadge",
  "version": "1.0.0",
  "intent": "状态标记、标签与计数气泡的统一入口；禁止在业务页手写 span+bg 实现类似效果。",
  "wraps": {
    "module": "@/components/starter/badge",
    "primitives": ["Badge"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "标签文案",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "视觉变体",
      "type": "\"default\" | \"secondary\" | \"destructive\" | \"outline\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": ["border-transparent", "bg-primary", "text-primary-foreground", "shadow"],
        "secondary": ["border-transparent", "bg-secondary", "text-secondary-foreground"],
        "destructive": ["border-transparent", "bg-destructive", "text-destructive-foreground", "shadow"],
        "outline": ["text-foreground"]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "inline-flex",
      "items-center",
      "rounded-md",
      "border",
      "px-2.5",
      "py-0.5",
      "text-xs",
      "font-semibold",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖内边距",
        "pattern": "^(px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "禁止覆盖圆角与边框",
        "pattern": "^(border|rounded)"
      },
      {
        "description": "禁止覆盖品牌/语义色（由 variant 映射）",
        "pattern": "^(bg|text)-(primary|secondary|destructive|accent|muted)"
      },
      {
        "description": "禁止任意值间距",
        "pattern": "^(m|p|gap)-\\["
      }
    ]
  },
  "aiPrompt": "需要标签/徽章时必须使用 @/components/business/BusinessBadge；通过 variant 控制风格，禁止手写背景色和间距。",
  "forbidden": [],
  "corrections": [],
  "referencePriority": [
    "@/components/business/BusinessBadge",
    "@/components/business"
  ],
  "meta": {
    "tags": ["badge", "tag", "label", "status"],
    "category": "data-display",
    "status": "stable"
  }
}
