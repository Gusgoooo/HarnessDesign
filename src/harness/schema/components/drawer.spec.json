{
  "id": "drawer",
  "componentName": "Drawer",
  "version": "1.0.0",
  "intent": "底部/侧边抽屉面板，适用于移动端操作面板或辅助内容展示。",
  "wraps": {
    "module": "@/components/starter/drawer",
    "primitives": [
      "Drawer",
      "DrawerPortal",
      "DrawerOverlay",
      "DrawerTrigger",
      "DrawerClose",
      "DrawerContent",
      "DrawerHeader",
      "DrawerFooter",
      "DrawerTitle",
      "DrawerDescription"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "fixed",
      "inset-x-0",
      "bottom-0",
      "z-50",
      "mt-8",
      "flex",
      "h-auto",
      "flex-col",
      "border",
      "bg-background"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖层级定位",
        "pattern": "^(z-|fixed|absolute|inset)"
      },
      {
        "description": "禁止覆盖动画（由组件内部控制）",
        "pattern": "^(animate-|transition-|duration-)"
      }
    ]
  },
  "aiPrompt": "使用 Drawer 时从 @/components/starter/drawer 导入；底部/侧边抽屉面板，适用于移动端操作面板或辅助内容展示。",
  "meta": {
    "tags": [
      "drawer",
      "overlay"
    ],
    "category": "overlay",
    "status": "stable"
  }
}
