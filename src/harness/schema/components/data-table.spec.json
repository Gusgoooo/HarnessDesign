{
  "id": "business-data-table",
  "componentName": "DataTable",
  "version": "1.0.0",
  "intent": "展示业务列表数据的主表格：分页、排序、批量操作在此收敛；禁止在业务页散落原生 <table> 与任意间距类。",
  "wraps": {
    "module": "@/components/ui/table",
    "primitives": [
      "Table",
      "TableHeader",
      "TableBody",
      "TableRow",
      "TableHead",
      { "symbol": "TableCell", "displayName": "数据单元格（TableCell）" }
    ]
  },
  "requiredProps": [
    {
      "name": "columns",
      "description": "列定义（含 accessor 与 header），由业务 schema 驱动",
      "type": "ColumnDef<T>[]",
      "required": true
    },
    {
      "name": "data",
      "description": "行数据数组",
      "type": "T[]",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "density",
      "description": "行高密度：紧凑列表 vs 舒适阅读",
      "type": "\"compact\" | \"comfortable\" | \"default\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "compact": ["text-xs", "py-business-table-cell-y-compact", "px-3"],
        "comfortable": ["text-sm", "py-business-table-cell-y-comfortable", "px-4"],
        "default": ["text-sm", "py-business-table-cell-y-default", "px-3"]
      }
    },
    {
      "name": "variant",
      "description": "视觉变体（斑马纹等）",
      "type": "\"plain\" | \"striped\"",
      "required": false,
      "defaultValue": "plain",
      "enumMap": {
        "plain": [],
        "striped": ["even:bg-muted/40"]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "w-full",
      "caption-bottom",
      "text-sm",
      "border-collapse"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖单元格与表头核心垂直内边距（由 density 映射）",
        "pattern": "^(p|px|py|pt|pb|pl|pr)-"
      },
      {
        "description": "禁止改动表格外边框与分割线语义",
        "pattern": "^(border|rounded|ring|outline|divide)-"
      },
      {
        "description": "禁止覆盖品牌/语义色",
        "pattern": "^(bg|text|border)-(primary|secondary|destructive|accent|muted|card|popover)"
      },
      {
        "description": "禁止任意值间距（AI 硬编码 m-[13px] 等）",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "展示表格数据时必须使用 @/components/business/DataTable；通过 density/variant 表达密度与斑马纹，禁止在 JSX 上堆叠 p-/m-/border-/bg-primary 等 Tailwind；列宽用 columns 元数据或模板列，不要手写 w-[13px]。颜色与边框仅允许来自全局令牌 src/design-tokens/tokens.json 所映射的语义类（如 border-border、bg-muted），禁止手写 oklch/hex 离散值。",
  "forbidden": [
    {
      "htmlTag": "table",
      "reason": "业务列表应走统一 DataTable，以确保间距与品牌锁一致",
      "useInstead": "@/components/business/DataTable"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-table",
      "violation": "在 features/** 或 pages/** 使用原生 <table>",
      "fixPrompt": "替换为 import { DataTable } from '@/components/business/DataTable'，数据与列定义传入 props。"
    },
    {
      "id": "no-hacky-spacing",
      "violation": "在 DataTable 子树使用 m-[13px]、p-[7px] 等任意值",
      "fixPrompt": "删除任意值 class，改用 DataTable 的 density 或设计约定的列模板。"
    }
  ],
  "referencePriority": [
    "@/components/business/DataTable",
    "@/components/business"
  ],
  "tailwindExtend": {
    "spacing": {
      "business-table-cell-y-compact": "0.5rem",
      "business-table-cell-y-default": "0.75rem",
      "business-table-cell-y-comfortable": "1rem"
    }
  },
  "meta": {
    "tags": ["table", "list", "data-grid"],
    "portalConfigFile": "data-table.spec.json"
  }
}
