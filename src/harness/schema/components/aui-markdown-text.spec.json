{
  "id": "aui-markdown-text",
  "componentName": "MarkdownText",
  "version": "1.0.0",
  "intent": "AI 消息中的 Markdown 渲染器。将 AI 返回的 Markdown 文本渲染为格式化 HTML（标题、列表、代码块、表格、链接等）。",
  "wraps": {
    "module": "@/components/starter/ai/markdown-text",
    "primitives": ["MarkdownText"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "prose",
      "text-sm",
      "text-foreground",
      "rounded-md",
      "bg-muted",
      "font-mono"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖排版样式（由 prose 统一控制）",
        "pattern": "^(prose|leading-|tracking-)"
      },
      {
        "description": "禁止覆盖代码块字体",
        "pattern": "^font-(mono|sans|serif)"
      },
      {
        "description": "禁止覆盖代码块背景色",
        "pattern": "^bg-(muted|zinc|gray|slate)"
      }
    ]
  },
  "aiPrompt": "AI 消息的 Markdown 渲染由 MarkdownText 组件自动处理（在 Thread 内部使用）；不需要手动调用；如果需要在 Thread 外渲染 Markdown，从 @/components/starter/ai/markdown-text 导入 MarkdownText。",
  "referencePriority": [
    "@/components/starter/ai/markdown-text"
  ],
  "examples": [
    {
      "title": "Thread 外独立使用",
      "snippet": "import { MarkdownText } from '@/components/starter/ai/markdown-text';\n\n<MarkdownText />"
    }
  ],
  "meta": {
    "tags": ["markdown", "text", "prose", "render", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
