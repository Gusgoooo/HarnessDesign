{
  "id": "kbd",
  "componentName": "Kbd",
  "version": "1.0.0",
  "intent": "键盘快捷键标签，展示按键组合（如 Ctrl+S）的视觉样式。",
  "wraps": {
    "module": "@/components/starter/kbd",
    "primitives": [
      "Kbd",
      "KbdGroup"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "bg-muted",
      "text-muted-foreground",
      "pointer-events-none",
      "inline-flex",
      "h-5",
      "w-fit",
      "min-w-5",
      "select-none",
      "items-center",
      "justify-center",
      "gap-1",
      "rounded-sm"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖字体",
        "pattern": "^(font-family|font-mono|font-sans)"
      }
    ]
  },
  "aiPrompt": "使用 Kbd 时从 @/components/starter/kbd 导入；键盘快捷键标签，展示按键组合（如 Ctrl+S）的视觉样式。",
  "meta": {
    "tags": [
      "kbd",
      "typography"
    ],
    "category": "typography",
    "status": "stable"
  }
}
