{
  "id": "aui-reasoning",
  "componentName": "Reasoning",
  "version": "1.0.0",
  "intent": "AI 推理过程展示组件（思维链）。可折叠面板，展示 AI 的思考过程，支持 outline/ghost/muted 三种视觉变体。",
  "wraps": {
    "module": "@/components/starter/ai/reasoning",
    "primitives": ["ReasoningRoot", "ReasoningTrigger", "ReasoningContent", "ReasoningText"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "组件结构：ReasoningTrigger + ReasoningContent > ReasoningText",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "视觉变体",
      "type": "\"outline\" | \"ghost\" | \"muted\"",
      "required": false,
      "defaultValue": "outline",
      "enumMap": {
        "outline": ["rounded-lg", "border", "px-3", "py-2"],
        "ghost": [],
        "muted": ["rounded-lg", "bg-muted/50", "px-3", "py-2"]
      }
    },
    {
      "name": "defaultOpen",
      "description": "初始展开状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "mb-4",
      "w-full",
      "rounded-lg",
      "border",
      "px-3",
      "py-2",
      "text-sm",
      "text-muted-foreground",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖动画（折叠由内部控制）",
        "pattern": "^(animate-|transition-|duration-)"
      },
      {
        "description": "禁止覆盖圆角与边框（由 variant 映射）",
        "pattern": "^(rounded|border)"
      },
      {
        "description": "禁止覆盖背景色（由 variant 映射）",
        "pattern": "^bg-(muted|secondary|accent|background)"
      }
    ]
  },
  "aiPrompt": "展示 AI 思维链/推理过程时使用 Reasoning 组件；结构为 ReasoningRoot > ReasoningTrigger + ReasoningContent > ReasoningText；通过 variant 控制视觉风格；禁止自己实现折叠面板模拟推理展示。",
  "referencePriority": [
    "@/components/starter/ai/reasoning"
  ],
  "examples": [
    {
      "title": "展示推理过程",
      "snippet": "<ReasoningRoot variant=\"outline\" defaultOpen={isStreaming}>\n  <ReasoningTrigger active={isStreaming} />\n  <ReasoningContent>\n    <ReasoningText>{children}</ReasoningText>\n  </ReasoningContent>\n</ReasoningRoot>"
    }
  ],
  "meta": {
    "tags": ["reasoning", "thinking", "chain-of-thought", "collapsible", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
