{
  "id": "aui-tooltip-icon-button",
  "componentName": "TooltipIconButton",
  "version": "1.0.0",
  "intent": "带 Tooltip 的图标按钮。用于 AI 界面中的操作按钮（复制、编辑、重试等），悬停显示文字提示。",
  "wraps": {
    "module": "@/components/starter/ai/tooltip-icon-button",
    "primitives": ["TooltipIconButton"]
  },
  "requiredProps": [
    {
      "name": "tooltip",
      "description": "悬停提示文字",
      "type": "string",
      "required": true
    },
    {
      "name": "children",
      "description": "图标元素",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "side",
      "description": "Tooltip 弹出方向",
      "type": "\"top\" | \"bottom\" | \"left\" | \"right\"",
      "required": false,
      "defaultValue": "bottom"
    },
    {
      "name": "variant",
      "description": "按钮变体（继承 Button）",
      "type": "\"default\" | \"outline\" | \"ghost\"",
      "required": false,
      "defaultValue": "ghost"
    },
    {
      "name": "size",
      "description": "按钮尺寸（继承 Button）",
      "type": "\"default\" | \"sm\" | \"lg\" | \"icon\"",
      "required": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "rounded-md",
      "transition-colors",
      "hover:bg-accent",
      "hover:text-accent-foreground"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖按钮尺寸（由 size 映射）",
        "pattern": "^(h-|w-|size-|p-|px-|py-)"
      },
      {
        "description": "禁止覆盖圆角",
        "pattern": "^rounded"
      },
      {
        "description": "禁止覆盖 Tooltip 定位",
        "pattern": "^(z-|fixed|absolute)"
      }
    ]
  },
  "aiPrompt": "AI 界面中的图标操作按钮使用 TooltipIconButton；必须传 tooltip prop 提供无障碍说明；通常 variant='ghost' size='icon'；禁止在 AI 界面用裸 Button + 单独 Tooltip 组合。",
  "referencePriority": [
    "@/components/starter/ai/tooltip-icon-button"
  ],
  "corrections": [
    {
      "id": "no-raw-button-tooltip-combo",
      "violation": "在 AI 界面中用 <Tooltip><Button size='icon'>...</Button></Tooltip> 手动组合",
      "fixPrompt": "使用 import { TooltipIconButton } from '@/components/starter/ai/tooltip-icon-button'，传入 tooltip prop 即可，无需手动嵌套 Tooltip + Button。"
    }
  ],
  "examples": [
    {
      "title": "复制按钮",
      "snippet": "<TooltipIconButton tooltip=\"Copy\" variant=\"ghost\">\n  <CopyIcon />\n</TooltipIconButton>"
    }
  ],
  "meta": {
    "tags": ["button", "icon", "tooltip", "action", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
