{
  "id": "aui-model-selector",
  "componentName": "ModelSelector",
  "version": "1.0.0",
  "intent": "AI 模型选择器。下拉菜单让用户切换当前对话使用的 AI 模型，支持图标、描述和禁用状态。",
  "wraps": {
    "module": "@/components/starter/ai/model-selector",
    "primitives": ["ModelSelector", "ModelSelectorRoot", "ModelSelectorTrigger", "ModelSelectorContent"]
  },
  "requiredProps": [
    {
      "name": "models",
      "description": "可选模型列表",
      "type": "ModelOption[]",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "触发器视觉变体",
      "type": "\"outline\" | \"ghost\" | \"muted\"",
      "required": false,
      "defaultValue": "outline"
    },
    {
      "name": "size",
      "description": "触发器尺寸",
      "type": "\"sm\" | \"default\" | \"lg\"",
      "required": false,
      "defaultValue": "default"
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "rounded-md",
      "border",
      "text-sm",
      "bg-popover",
      "shadow-lg",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖下拉框定位与层级",
        "pattern": "^(z-|fixed|absolute)"
      },
      {
        "description": "禁止覆盖触发器高度与内边距（由 size 映射）",
        "pattern": "^(h-|px-|py-)"
      },
      {
        "description": "禁止覆盖下拉框背景与边框",
        "pattern": "^(bg|border)-(popover|input|background)"
      }
    ]
  },
  "aiPrompt": "需要模型切换功能时使用 ModelSelector；传入 models 数组（含 id/name/description/icon）；简单场景直接用 <ModelSelector models={...} />，需要自定义布局用 Root/Trigger/Content 组合。",
  "referencePriority": [
    "@/components/starter/ai/model-selector"
  ],
  "examples": [
    {
      "title": "简单模型选择器",
      "snippet": "const models = [\n  { id: \"gpt-4\", name: \"GPT-4\", description: \"Most capable\" },\n  { id: \"gpt-3.5\", name: \"GPT-3.5\", description: \"Fast\" },\n];\n\n<ModelSelector models={models} variant=\"outline\" />"
    },
    {
      "title": "受控模型选择器",
      "snippet": "<ModelSelector\n  models={models}\n  value={selectedModel}\n  onValueChange={setSelectedModel}\n  variant=\"ghost\"\n  size=\"sm\"\n/>"
    }
  ],
  "meta": {
    "tags": ["model", "selector", "dropdown", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
