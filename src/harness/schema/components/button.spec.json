{
  "id": "button",
  "componentName": "Button",
  "version": "1.0.0",
  "intent": "所有可点击行为的统一入口：主操作、次要操作、链接导航等；禁止在业务页散落原生 <button> 并手写间距与品牌色。",
  "wraps": {
    "module": "@/components/starter/button",
    "primitives": [
      "Button"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "按钮文案或图标",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "视觉变体",
      "type": "\"default\" | \"destructive\" | \"outline\" | \"secondary\" | \"ghost\" | \"link\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "bg-primary",
          "text-primary-foreground",
          "shadow",
          "hover:bg-primary/90"
        ],
        "destructive": [
          "bg-destructive",
          "text-destructive-foreground",
          "shadow-sm",
          "hover:bg-destructive/90"
        ],
        "outline": [
          "border",
          "border-input",
          "bg-background",
          "shadow-sm",
          "hover:bg-accent",
          "hover:text-accent-foreground"
        ],
        "secondary": [
          "bg-secondary",
          "text-secondary-foreground",
          "shadow-sm",
          "hover:bg-secondary/80"
        ],
        "ghost": [
          "hover:bg-accent",
          "hover:text-accent-foreground"
        ],
        "link": [
          "text-primary",
          "underline-offset-4",
          "hover:underline"
        ]
      }
    },
    {
      "name": "size",
      "description": "尺寸规格",
      "type": "\"default\" | \"sm\" | \"lg\" | \"icon\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "h-9",
          "px-4",
          "py-2",
          "text-sm"
        ],
        "sm": [
          "h-7",
          "px-3",
          "text-xs"
        ],
        "lg": [
          "h-11",
          "px-8",
          "text-sm"
        ],
        "icon": [
          "size-9",
          "shrink-0",
          "p-0"
        ]
      }
    },
    {
      "name": "disabled",
      "description": "禁用状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "inline-flex",
      "items-center",
      "justify-center",
      "rounded-md",
      "text-sm",
      "font-medium",
      "transition-colors",
      "focus-visible:outline-none",
      "focus-visible:ring-1",
      "focus-visible:ring-ring",
      "disabled:pointer-events-none",
      "disabled:opacity-50"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖按钮高度与内边距（由 size 映射）",
        "pattern": "^(h-|px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "禁止覆盖圆角（由 design token --radius 驱动）",
        "pattern": "^rounded"
      },
      {
        "description": "禁止覆盖品牌/语义色（由 variant 映射）",
        "pattern": "^(bg|text|border)-(primary|secondary|destructive|accent|muted)"
      },
      {
        "description": "禁止任意值间距",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "需要按钮时必须使用 @/components/starter/button；通过 variant 控制视觉风格，通过 size 控制尺寸；禁止在 JSX 上堆叠 h-/px-/bg-primary 等 Tailwind 覆盖。颜色仅允许 design token 语义类。",
  "forbidden": [
    {
      "htmlTag": "button",
      "reason": "业务场景禁止裸 <button>，以保证圆角、间距与品牌色一致",
      "useInstead": "@/components/starter/button"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-button",
      "violation": "在 features/** 或 pages/** 使用原生 <button>",
      "fixPrompt": "替换为 import { Button } from '@/components/starter/Button'，用 variant 和 size props 控制样式。"
    }
  ],
  "referencePriority": [
    "@/components/starter/button",
    "@/components/starter"
  ],
  "meta": {
    "tags": [
      "button",
      "action",
      "cta"
    ],
    "category": "action",
    "status": "stable"
  }
}
