{
  "id": "aui-assistant-modal",
  "componentName": "AssistantModal",
  "version": "1.0.0",
  "intent": "悬浮式 AI 助手弹窗。在页面右下角显示一个触发按钮，点击后弹出包含完整 Thread 的浮窗。适合需要在任意页面嵌入 AI 助手的场景。",
  "wraps": {
    "module": "@/components/starter/ai/assistant-modal",
    "primitives": ["AssistantModal"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "fixed",
      "z-50",
      "rounded-xl",
      "border",
      "bg-popover",
      "shadow-md",
      "overflow-clip"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖定位与层级",
        "pattern": "^(z-|fixed|absolute|inset|end-|bottom-)"
      },
      {
        "description": "禁止覆盖弹窗尺寸",
        "pattern": "^(h-|w-|max-h-|max-w-)"
      },
      {
        "description": "禁止覆盖动画",
        "pattern": "^(animate-|transition-|duration-|data-\\[state)"
      },
      {
        "description": "禁止覆盖弹窗背景与边框",
        "pattern": "^(bg|border)-(popover|border|background)"
      }
    ]
  },
  "aiPrompt": "需要在页面角落嵌入浮窗式 AI 助手时使用 AssistantModal；需要包裹在 AssistantRuntimeProvider 内；组件自带触发按钮和弹窗容器，内部渲染完整 Thread。适合非 AI 核心页面的辅助场景。",
  "referencePriority": [
    "@/components/starter/ai/assistant-modal"
  ],
  "examples": [
    {
      "title": "页面角落悬浮助手",
      "snippet": "<AssistantRuntimeProvider runtime={runtime}>\n  <YourPageContent />\n  <AssistantModal />\n</AssistantRuntimeProvider>"
    }
  ],
  "meta": {
    "tags": ["modal", "popup", "floating", "assistant", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
