{
  "id": "field",
  "componentName": "Field",
  "version": "1.0.0",
  "intent": "表单字段容器，统一 label + input + description + error 的布局与无障碍绑定。",
  "wraps": {
    "module": "@/components/starter/field",
    "primitives": [
      "Field",
      "FieldLabel",
      "FieldDescription",
      "FieldError",
      "FieldGroup",
      "FieldLegend",
      "FieldSeparator",
      "FieldSet",
      "FieldContent",
      "FieldTitle"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-col",
      "gap-6"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖布局结构",
        "pattern": "^(flex|grid|gap-)"
      }
    ]
  },
  "aiPrompt": "使用 Field 时从 @/components/starter/field 导入；表单字段容器，统一 label + input + description + error 的布局与无障碍绑定。",
  "meta": {
    "tags": [
      "field",
      "form"
    ],
    "category": "form",
    "status": "stable"
  }
}
