{
  "id": "carousel",
  "componentName": "Carousel",
  "version": "1.0.0",
  "intent": "轮播/走马灯容器，用于产品图片、banner、卡片列表等水平滚动展示。",
  "wraps": {
    "module": "@/components/starter/carousel",
    "primitives": [
      "Carousel",
      "CarouselContent",
      "CarouselItem",
      "CarouselPrevious",
      "CarouselNext"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "relative"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖溢出与定位",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "使用 Carousel 时从 @/components/starter/carousel 导入；轮播/走马灯容器，用于产品图片、banner、卡片列表等水平滚动展示。",
  "meta": {
    "tags": [
      "carousel",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
