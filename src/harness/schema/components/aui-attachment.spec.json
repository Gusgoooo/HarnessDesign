{
  "id": "aui-attachment",
  "componentName": "Attachment",
  "version": "1.0.0",
  "intent": "AI 对话中的附件展示与上传组件。包含用户消息附件预览、输入框附件列表、添加附件按钮。",
  "wraps": {
    "module": "@/components/starter/ai/attachment",
    "primitives": ["UserMessageAttachments", "ComposerAttachments", "ComposerAddAttachment"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "gap-2",
      "rounded-lg",
      "border",
      "bg-muted/50",
      "text-sm"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖附件容器圆角与边框",
        "pattern": "^(rounded|border)"
      },
      {
        "description": "禁止覆盖附件缩略图尺寸",
        "pattern": "^(h-|w-|size-)"
      },
      {
        "description": "禁止覆盖背景色",
        "pattern": "^bg-(muted|card|background)"
      }
    ]
  },
  "aiPrompt": "AI 对话中的附件功能由 Attachment 组件系列自动处理（在 Thread 内部使用）；UserMessageAttachments 展示已发送附件，ComposerAttachments 展示待发送附件，ComposerAddAttachment 是添加按钮。通常无需手动使用。",
  "referencePriority": [
    "@/components/starter/ai/attachment"
  ],
  "meta": {
    "tags": ["attachment", "file", "image", "upload", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
