{
  "id": "resizable",
  "componentName": "Resizable",
  "version": "1.0.0",
  "intent": "可拖拽调整大小的面板组，用于 IDE 式多面板布局。",
  "wraps": {
    "module": "@/components/starter/resizable",
    "primitives": [
      "ResizablePanelGroup",
      "ResizablePanel",
      "ResizableHandle"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "w-full"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖溢出与定位",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "使用 Resizable 时从 @/components/starter/resizable 导入；可拖拽调整大小的面板组，用于 IDE 式多面板布局。",
  "meta": {
    "tags": [
      "resizable",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
