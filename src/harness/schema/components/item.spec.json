{
  "id": "item",
  "componentName": "Item",
  "version": "1.0.0",
  "intent": "列表项布局组件，提供图标/媒体 + 文本 + 操作按钮的标准行结构。",
  "wraps": {
    "module": "@/components/starter/item",
    "primitives": [
      "Item",
      "ItemMedia",
      "ItemContent",
      "ItemActions",
      "ItemGroup",
      "ItemSeparator",
      "ItemTitle",
      "ItemDescription",
      "ItemHeader",
      "ItemFooter"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "variant 变体",
      "type": "\"default\" | \"icon\" | \"image\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "bg-transparent"
        ],
        "icon": [
          "bg-muted",
          "size-8",
          "rounded-sm",
          "border",
          "[&_svg:not([class*="
        ],
        "image": [
          "size-8",
          "overflow-hidden",
          "rounded-sm",
          "[&_img]:size-full",
          "[&_img]:object-cover"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-col"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖溢出与定位",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "使用 Item 时从 @/components/starter/item 导入；列表项布局组件，提供图标/媒体 + 文本 + 操作按钮的标准行结构。",
  "meta": {
    "tags": [
      "item",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
