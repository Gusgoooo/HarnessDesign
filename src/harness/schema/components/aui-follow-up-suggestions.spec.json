{
  "id": "aui-follow-up-suggestions",
  "componentName": "FollowUpSuggestions",
  "version": "1.0.0",
  "intent": "AI 回复后的跟进建议按钮组。在助手消息下方展示可点击的后续问题建议。",
  "wraps": {
    "module": "@/components/starter/ai/follow-up-suggestions",
    "primitives": ["ThreadFollowupSuggestions"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-wrap",
      "gap-2",
      "rounded-full",
      "border",
      "bg-background",
      "text-sm",
      "transition-colors",
      "hover:bg-muted"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖建议按钮圆角",
        "pattern": "^rounded"
      },
      {
        "description": "禁止覆盖交互状态色",
        "pattern": "^(bg|text|border)-(muted|accent|background)"
      },
      {
        "description": "禁止覆盖动画",
        "pattern": "^(animate-|transition-)"
      }
    ]
  },
  "aiPrompt": "AI 回复后的跟进建议由 ThreadFollowupSuggestions 组件自动渲染（在 Thread 内部使用）；通常无需手动使用；建议内容由 runtime 的 suggestions 接口提供。",
  "referencePriority": [
    "@/components/starter/ai/follow-up-suggestions"
  ],
  "meta": {
    "tags": ["suggestions", "follow-up", "quick-reply", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
