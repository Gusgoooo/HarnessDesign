{
  "id": "toggle-group",
  "componentName": "ToggleGroup",
  "version": "1.0.0",
  "intent": "切换按钮组，一组互斥或多选的 toggle 按钮（如视图模式：列表/网格/看板）。",
  "wraps": {
    "module": "@/components/starter/toggle-group",
    "primitives": [
      "ToggleGroup",
      "ToggleGroupItem"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "items-center",
      "justify-center",
      "gap-1"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 ToggleGroup 时从 @/components/starter/toggle-group 导入；切换按钮组，一组互斥或多选的 toggle 按钮（如视图模式：列表/网格/看板）。",
  "meta": {
    "tags": [
      "toggle-group",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
