{
  "id": "accordion",
  "componentName": "Accordion",
  "version": "1.0.0",
  "intent": "可折叠内容面板组，适用于 FAQ、设置分组等需要逐项展开的场景。",
  "wraps": {
    "module": "@/components/starter/accordion",
    "primitives": [
      "Accordion",
      "AccordionItem",
      "AccordionTrigger",
      "AccordionContent"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "border-b"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖过渡动画",
        "pattern": "^(transition-|duration-|data-)"
      }
    ]
  },
  "aiPrompt": "使用 Accordion 时从 @/components/starter/accordion 导入；可折叠内容面板组，适用于 FAQ、设置分组等需要逐项展开的场景。",
  "meta": {
    "tags": [
      "accordion",
      "disclosure"
    ],
    "category": "disclosure",
    "status": "stable"
  }
}
