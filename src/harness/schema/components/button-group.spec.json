{
  "id": "button-group",
  "componentName": "ButtonGroup",
  "version": "1.0.0",
  "intent": "按钮编组容器，将相关操作按钮视觉上组合为一组（如工具栏、分段控件）。",
  "wraps": {
    "module": "@/components/starter/button-group",
    "primitives": [
      "ButtonGroup",
      "ButtonGroupSeparator",
      "ButtonGroupText"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "bg-muted",
      "shadow-xs",
      "flex",
      "items-center",
      "gap-2",
      "rounded-md",
      "border",
      "px-4",
      "text-sm",
      "font-medium"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖溢出与定位",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "使用 ButtonGroup 时从 @/components/starter/button-group 导入；按钮编组容器，将相关操作按钮视觉上组合为一组（如工具栏、分段控件）。",
  "meta": {
    "tags": [
      "button-group",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
