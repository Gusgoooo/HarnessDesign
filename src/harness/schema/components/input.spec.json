{
  "id": "business-input",
  "componentName": "BusinessInput",
  "version": "1.0.0",
  "intent": "所有文本输入场景的统一入口：搜索、表单字段、密码等；禁止在业务页散落原生 <input> 并手写间距与边框。",
  "wraps": {
    "module": "@/components/starter/input",
    "primitives": ["Input"]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "type",
      "description": "输入类型",
      "type": "\"text\" | \"password\" | \"email\" | \"number\" | \"search\" | \"tel\" | \"url\"",
      "required": false,
      "defaultValue": "text"
    },
    {
      "name": "placeholder",
      "description": "占位文本",
      "type": "string",
      "required": false
    },
    {
      "name": "disabled",
      "description": "禁用状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-9",
      "w-full",
      "min-w-0",
      "rounded-md",
      "border",
      "border-input",
      "bg-transparent",
      "px-3",
      "py-1",
      "text-sm",
      "shadow-sm",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖输入框高度与内边距",
        "pattern": "^(h-|px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "禁止覆盖边框与圆角",
        "pattern": "^(border|rounded|ring|outline)"
      },
      {
        "description": "禁止任意值间距",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "需要文本输入时必须使用 @/components/business/BusinessInput；禁止在 JSX 上堆叠 h-/px-/border- 等 Tailwind 覆盖。",
  "forbidden": [
    {
      "htmlTag": "input",
      "reason": "业务场景禁止裸 <input>，以保证高度、边框与 focus 样式一致",
      "useInstead": "@/components/business/BusinessInput"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-input",
      "violation": "在 features/** 或 pages/** 使用原生 <input>",
      "fixPrompt": "替换为 import { BusinessInput } from '@/components/business/BusinessInput'。"
    }
  ],
  "referencePriority": [
    "@/components/business/BusinessInput",
    "@/components/business"
  ],
  "meta": {
    "tags": ["input", "text-field", "form"],
    "category": "form",
    "status": "stable"
  }
}
