{
  "id": "aui-thread",
  "componentName": "Thread",
  "version": "1.0.0",
  "intent": "AI 对话线程主容器，包含消息列表、欢迎页面、输入框（Composer）及滚动控制。是 assistant-ui 的核心组件。",
  "wraps": {
    "module": "@/components/starter/ai/thread",
    "primitives": ["Thread"]
  },
  "requiredProps": [],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "flex-col",
      "bg-background",
      "overflow-y-scroll",
      "scroll-smooth",
      "rounded-3xl",
      "border",
      "text-sm",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖滚动与溢出行为",
        "pattern": "^overflow"
      },
      {
        "description": "禁止覆盖动画（由内部控制）",
        "pattern": "^(animate-|transition-|duration-)"
      },
      {
        "description": "禁止覆盖背景色（由 token 驱动）",
        "pattern": "^bg-(background|popover|accent|muted|primary|secondary)"
      },
      {
        "description": "禁止覆盖容器高度（由父级控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "AI 对话场景使用 Thread 组件；需要包裹在 AssistantRuntimeProvider 内使用；Thread 自带消息列表、欢迎页、输入框，无需手动拼装；禁止自己实现聊天 UI。",
  "forbidden": [
    {
      "htmlTag": "div",
      "reason": "禁止在业务页面手写聊天容器（div+输入框+消息列表）代替 Thread 组件",
      "useInstead": "@/components/starter/ai/thread"
    }
  ],
  "corrections": [
    {
      "id": "no-manual-chat-ui",
      "violation": "手动拼装 input + message list 实现对话 UI",
      "fixPrompt": "使用 import { Thread } from '@/components/starter/ai/thread'，并将其包裹在 AssistantRuntimeProvider 中。Thread 已内置消息列表、欢迎页、Composer 输入框。"
    }
  ],
  "referencePriority": [
    "@/components/starter/ai/thread"
  ],
  "examples": [
    {
      "title": "基础 AI 对话页面",
      "snippet": "<AssistantRuntimeProvider runtime={runtime}>\n  <Thread />\n</AssistantRuntimeProvider>"
    }
  ],
  "meta": {
    "tags": ["chat", "thread", "conversation", "ai", "assistant"],
    "category": "ai",
    "status": "stable"
  }
}
