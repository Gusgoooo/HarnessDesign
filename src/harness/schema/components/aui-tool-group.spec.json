{
  "id": "aui-tool-group",
  "componentName": "ToolGroup",
  "version": "1.0.0",
  "intent": "AI 工具调用分组容器。将多个 ToolFallback 聚合在一个可折叠面板中，显示工具调用计数和活跃状态。",
  "wraps": {
    "module": "@/components/starter/ai/tool-group",
    "primitives": ["ToolGroupRoot", "ToolGroupTrigger", "ToolGroupContent"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "ToolGroupTrigger + ToolGroupContent 结构",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "视觉变体",
      "type": "\"outline\" | \"ghost\" | \"muted\"",
      "required": false,
      "defaultValue": "outline",
      "enumMap": {
        "outline": ["rounded-lg", "border", "py-3"],
        "ghost": [],
        "muted": ["rounded-lg", "border", "border-muted-foreground/30", "bg-muted/30", "py-3"]
      }
    },
    {
      "name": "defaultOpen",
      "description": "初始展开状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "count",
      "description": "工具调用计数（Trigger 显示）",
      "type": "number",
      "required": false
    },
    {
      "name": "active",
      "description": "是否正在执行（Trigger 显示旋转动画）",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "w-full",
      "rounded-lg",
      "border",
      "px-3",
      "py-2",
      "text-sm",
      "text-muted-foreground"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖动画（折叠与旋转由内部控制）",
        "pattern": "^(animate-|transition-|duration-)"
      },
      {
        "description": "禁止覆盖圆角与边框（由 variant 映射）",
        "pattern": "^(rounded|border)"
      },
      {
        "description": "禁止覆盖背景色（由 variant 映射）",
        "pattern": "^bg-(muted|secondary|accent)"
      }
    ]
  },
  "aiPrompt": "需要聚合展示多个工具调用时使用 ToolGroup；结构为 ToolGroupRoot > ToolGroupTrigger + ToolGroupContent > (多个 ToolFallback)；通过 count 和 active 控制标题显示。",
  "referencePriority": [
    "@/components/starter/ai/tool-group"
  ],
  "examples": [
    {
      "title": "聚合工具调用",
      "snippet": "<ToolGroupRoot variant=\"outline\">\n  <ToolGroupTrigger count={3} active={isRunning} />\n  <ToolGroupContent>\n    {toolCalls.map(tc => <ToolFallback key={tc.id} {...tc} />)}\n  </ToolGroupContent>\n</ToolGroupRoot>"
    }
  ],
  "meta": {
    "tags": ["tool-group", "function-calls", "collapsible", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
