{
  "id": "empty",
  "componentName": "Empty",
  "version": "1.0.0",
  "intent": "空状态占位组件，当列表/页面无数据时展示说明文案和引导操作。",
  "wraps": {
    "module": "@/components/starter/empty",
    "primitives": [
      "Empty",
      "EmptyHeader",
      "EmptyTitle",
      "EmptyDescription",
      "EmptyContent",
      "EmptyMedia"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "variant 变体",
      "type": "\"default\" | \"icon\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "bg-transparent"
        ],
        "icon": [
          "bg-muted",
          "text-foreground",
          "flex",
          "size-8",
          "shrink-0",
          "items-center",
          "justify-center",
          "rounded-lg",
          "[&_svg:not([class*="
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "min-w-0",
      "flex-1",
      "flex-col",
      "items-center",
      "justify-center",
      "gap-6",
      "text-balance",
      "rounded-lg",
      "border-dashed",
      "p-6",
      "text-center"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖动画",
        "pattern": "^(animate-|transition-)"
      }
    ]
  },
  "aiPrompt": "使用 Empty 时从 @/components/starter/empty 导入；空状态占位组件，当列表/页面无数据时展示说明文案和引导操作。",
  "meta": {
    "tags": [
      "empty",
      "feedback"
    ],
    "category": "feedback",
    "status": "stable"
  }
}
