{
  "id": "input-otp",
  "componentName": "InputOtp",
  "version": "1.0.0",
  "intent": "一次性密码输入（OTP/验证码），固定位数的分格输入框。",
  "wraps": {
    "module": "@/components/starter/input-otp",
    "primitives": [
      "InputOTP",
      "InputOTPGroup",
      "InputOTPSlot",
      "InputOTPSeparator"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "子内容",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [],
    "blacklist": [
      {
        "description": "禁止覆盖焦点环样式",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "禁止覆盖高度（由 size 控制）",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "使用 InputOtp 时从 @/components/starter/input-otp 导入；一次性密码输入（OTP/验证码），固定位数的分格输入框。",
  "meta": {
    "tags": [
      "input-otp",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
