{
  "id": "aui-assistant-sidebar",
  "componentName": "AssistantSidebar",
  "version": "1.0.0",
  "intent": "侧边栏式 AI 助手。将页面分为主内容区和 AI 对话侧边栏，中间有可拖拽的分隔线。适合需要 AI 辅助的工作台场景。",
  "wraps": {
    "module": "@/components/starter/ai/assistant-sidebar",
    "primitives": ["AssistantSidebar"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "主内容区域",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "w-full",
      "border",
      "bg-background"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖布局结构（flex 分割由内部控制）",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      },
      {
        "description": "禁止覆盖分隔线与拖拽行为",
        "pattern": "^(cursor|resize)"
      },
      {
        "description": "禁止覆盖容器高度",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "需要侧边栏式 AI 助手时使用 AssistantSidebar；将 children 作为主内容区传入，AI 对话面板自动出现在右侧；需要包裹在 AssistantRuntimeProvider 内；适合工作台/IDE 类页面布局。",
  "referencePriority": [
    "@/components/starter/ai/assistant-sidebar"
  ],
  "examples": [
    {
      "title": "工作台布局",
      "snippet": "<AssistantRuntimeProvider runtime={runtime}>\n  <AssistantSidebar>\n    <YourWorkspaceContent />\n  </AssistantSidebar>\n</AssistantRuntimeProvider>"
    }
  ],
  "meta": {
    "tags": ["sidebar", "panel", "split", "assistant", "ai"],
    "category": "ai",
    "status": "stable"
  }
}
