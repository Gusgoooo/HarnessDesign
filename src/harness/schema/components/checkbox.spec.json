{
  "id": "business-checkbox",
  "componentName": "BusinessCheckbox",
  "version": "1.0.0",
  "intent": "勾选/取消勾选的统一入口：表单同意项、多选过滤器、批量选择等；禁止在业务页裸用 <input type=checkbox>。",
  "wraps": {
    "module": "@/components/starter/checkbox",
    "primitives": ["Checkbox"]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "disabled",
      "description": "禁用状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "defaultChecked",
      "description": "默认选中",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "h-4",
      "w-4",
      "shrink-0",
      "rounded",
      "border",
      "border-input",
      "accent-primary"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖尺寸",
        "pattern": "^(h-|w-|size-)"
      },
      {
        "description": "禁止覆盖边框与圆角",
        "pattern": "^(border|rounded)"
      },
      {
        "description": "禁止覆盖品牌色",
        "pattern": "^accent-"
      },
      {
        "description": "禁止任意值间距",
        "pattern": "^(m|p|gap)-\\["
      }
    ]
  },
  "aiPrompt": "需要勾选框时必须使用 @/components/business/BusinessCheckbox；禁止手写尺寸与品牌色。",
  "forbidden": [],
  "corrections": [],
  "referencePriority": [
    "@/components/business/BusinessCheckbox",
    "@/components/business"
  ],
  "meta": {
    "tags": ["checkbox", "toggle", "form"],
    "category": "form",
    "status": "stable"
  }
}
