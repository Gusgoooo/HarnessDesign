{
  "$comment": "harness-audit.mjs 读取；路径相对于仓库根目录匹配绝对路径子串",
  "scanRoots": ["src"],
  "excludePathSubstrings": [
    "/node_modules/",
    "/components/ui/",
    "/components/starter/",
    "/harness/schema/",
    "/design-portal/",
    "/design-tokens/",
    "/stories/",
    ".stories.",
    ".spec.json",
    "/__fixtures__/"
  ],
  "reportForbiddenHtmlFromSpecs": true,
  "flagArbitraryTailwind": true
}
