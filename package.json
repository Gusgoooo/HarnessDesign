{
  "name": "harnessui",
  "version": "0.1.0",
  "description": "AI-first component design kit — design tokens, Storybook portal, and harness CLI for building token-driven UI component libraries",
  "private": false,
  "type": "module",
  "license": "MIT",
  "keywords": ["design-tokens", "storybook", "tailwindcss", "ai-coding", "component-library", "harness"],
  "bin": {
    "harness": "./bin/harness.mjs"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "docs/",
    ".storybook/",
    "vendor/",
    "AGENTS.md",
    ".cursorrules",
    "tailwind.config.ts",
    "tsconfig.json",
    "postcss.config.mjs",
    "vite.config.ts",
    "vite-plugin-schema-api.mjs",
    "components.json",
    "harness-vite.d.ts",
    "tailwind.harness.generated.ts"
  ],
  "scripts": {
    "generate:rules": "node scripts/generate-cursorrules.mjs",
    "sync:tokens": "node scripts/emit-design-tokens-css.mjs",
    "sync:harness": "npm run sync:tokens && node scripts/sync-from-schema.mjs",
    "harness:audit": "node scripts/harness-audit.mjs",
    "dev:portal": "vite --config src/design-portal/vite.config.ts --open",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "react-docgen-typescript": "^2.2.2",
    "storybook": "^8.6.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
